# Copy to `.env.local`. Never committed.
# Mirrors backend/.env.example — every value is SERVER-SIDE ONLY.
# There is deliberately no NEXT_PUBLIC_* API url: the browser never talks to
# FastAPI directly, it goes through the BFF proxy at /api/bff/*.

# --- Backend ---
# Where FastAPI listens. Must match backend CORS_ORIGINS pointing back at :3000.
API_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# --- Cookies ---
# `true` in production (HTTPS only). Leave false for local http://localhost.
COOKIE_SECURE=false

# --- Public admissions form ---
# The school UUID whose public admissions form is served at /admissions.
# Optional: /admissions/<school_id> also works without this.
NEXT_PUBLIC_DEFAULT_SCHOOL_ID=
