# ---------------------------------------------------------------------------
# Copy to `.env` and fill in. `.env` is gitignored and NEVER committed.
# Every value here maps 1:1 to a field on app/core/config.py::Settings.
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="School Management System"
ENVIRONMENT=local                     # local | test | staging | production
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false                        # false = pretty console logs, true = JSON for log aggregators

# --- API ---
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]   # Next.js dev server

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_generate_a_64_byte_urlsafe_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---
# Leave DB_ENABLED=false until the PostgreSQL integration phase.
# The app boots and serves /health without a database when this is false.
DB_ENABLED=false
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=sms_app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=school_manage_db
DB_ECHO=false                         # true logs every SQL statement (dev only)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5

# --- Email / OTP ---
# console = render to the log, send nothing (default; safe for dev + tests)
# smtp    = actually deliver
EMAIL_BACKEND=console

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Port 587 -> START_TLS=true, USE_TLS=false
# Port 465 -> START_TLS=false, USE_TLS=true
# These are mutually exclusive. (Nodemailer's `secure: true` == SMTP_USE_TLS.)
SMTP_START_TLS=true
SMTP_USE_TLS=false
SMTP_USER=your.address@gmail.com
SMTP_PASSWORD=                        # Gmail App Password, NOT your account password
SMTP_TIMEOUT_SECONDS=15

# Must be a real mailbox. A bare display name is rejected by most receiving servers.
EMAIL_FROM_ADDRESS=noreply@yourdomain.com
EMAIL_FROM_NAME=School Manage

FRONTEND_URL=http://localhost:3000
EMAIL_LOGO_URL=                       # optional absolute URL for the email header
